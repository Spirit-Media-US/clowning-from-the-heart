# Cloudflare R2
R2_BUCKET=clowning-from-the-heart
R2_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://YOUR_PUBLIC_R2_URL
R2_ACCESS_KEY_ID=YOUR_ACCESS_KEY
R2_SECRET_ACCESS_KEY=YOUR_SECRET_KEY

# Sanity Studio (for future separate studio project)
SANITY_STUDIO_PROJECT_ID=zvhqn0sn
SANITY_STUDIO_DATASET=production
SANITY_STUDIO_API_VERSION=2026-03-11

# Astro frontend Sanity API access
PUBLIC_SANITY_PROJECT_ID=zvhqn0sn
PUBLIC_SANITY_DATASET=production
SANITY_API_VERSION=2026-03-11
SANITY_TOKEN=your_sanity_token_if_needed

# GoHighLevel
GHL_FORM_ID=your_form_id
GHL_FORM_EMBED_URL=your_embed_url
GHL_WEBHOOK_URL=your_webhook_url

# Site
PUBLIC_SITE_URL=https://yourdomain.com
