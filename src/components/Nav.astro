---
import { siteName, navLinks } from '../utils/site';

const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand" aria-label={siteName}>
      <span class="brand-icon" aria-hidden="true">🎪</span>
      <span class="brand-name">{siteName}</span>
    </a>

    <nav aria-label="Main navigation">
      <ul class="nav-list" role="list">
        {navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={['nav-link', { 'nav-link--active': currentPath === link.href }]}
              aria-current={currentPath === link.href ? 'page' : undefined}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <a href="/contact" class="nav-cta">Book Now</a>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: #fff;
    border-bottom: 1px solid #e5e7eb;
    padding-block: 1rem;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 700;
    font-size: 1.125rem;
    color: #1a1a1a;
    white-space: nowrap;
  }

  .brand-icon {
    font-size: 1.5rem;
  }

  .nav-list {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 0.25rem;
  }

  .nav-link {
    display: block;
    padding: 0.4rem 0.75rem;
    border-radius: 0.375rem;
    font-size: 0.9375rem;
    color: #374151;
    transition: background 0.15s, color 0.15s;
  }

  .nav-link:hover,
  .nav-link--active {
    background: #f3f4f6;
    color: #e63946;
  }

  .nav-cta {
    display: inline-block;
    padding: 0.5rem 1.25rem;
    background: #e63946;
    color: #fff;
    border-radius: 9999px;
    font-size: 0.9375rem;
    font-weight: 600;
    white-space: nowrap;
    transition: background 0.15s;
  }

  .nav-cta:hover {
    background: #c1121f;
  }

  @media (max-width: 640px) {
    .brand-name {
      display: none;
    }

    .nav-list {
      gap: 0;
    }

    .nav-link {
      font-size: 0.875rem;
      padding: 0.4rem 0.5rem;
    }

    .nav-cta {
      font-size: 0.875rem;
      padding: 0.4rem 0.875rem;
    }
  }
</style>
