---
import '../styles/global.css';
import { siteName, siteUrl, defaultTitle, defaultDescription, ogImage } from '../utils/site';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = defaultTitle,
  description = defaultDescription,
} = Astro.props;

const pageTitle = title === defaultTitle ? title : `${title} — ${siteName}`;
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="author" content="Cindy Love-Sprengel" />
    <meta name="theme-color" content="#d91c57" />
    <meta name="msvalidate.01" content="477910DF31D77AFDFCAE62DF5E095405" />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="768" />
    <meta property="og:image:height" content="1045" />
    <meta property="og:image:alt" content="Clowning from the Heart — One Smile at a Time book cover" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="Clowning from the Heart — One Smile at a Time book cover" />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Book",
          "name": "Clowning from the Heart: One Smile at a Time",
          "author": {
            "@type": "Person",
            "name": "Cindy Love-Sprengel"
          },
          "description": description,
          "image": ogImage,
          "url": siteUrl,
          "bookFormat": "https://schema.org/Paperback",
          "inLanguage": "en",
          "publisher": {
            "@type": "Organization",
            "name": "Clowning from the Heart"
          }
        },
        {
          "@type": "WebSite",
          "name": siteName,
          "url": siteUrl,
          "description": description
        }
      ]
    })} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.json" />

    <!-- Preload hero background (LCP) — responsive sizes -->
    <link rel="preload" as="image" href="https://cdn.sanity.io/images/zvhqn0sn/production/fb8dc970940222bd585caa544a1203f1b00f8110-2560x1920.jpg?w=800&auto=format" media="(max-width: 767px)" />
    <link rel="preload" as="image" href="https://cdn.sanity.io/images/zvhqn0sn/production/fb8dc970940222bd585caa544a1203f1b00f8110-2560x1920.jpg?w=1280&auto=format" media="(min-width: 768px) and (max-width: 1279px)" />
    <link rel="preload" as="image" href="https://cdn.sanity.io/images/zvhqn0sn/production/fb8dc970940222bd585caa544a1203f1b00f8110-2560x1920.jpg?w=1920&auto=format" media="(min-width: 1280px)" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Abril+Fatface&display=optional" rel="stylesheet" />

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-FCJRHY6N52" is:inline></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-FCJRHY6N52');
    </script>
  </head>
  <body>
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:rounded focus:bg-primary focus:px-4 focus:py-2 focus:text-white">
      Skip to content
    </a>
    <main id="main-content">
      <slot />
    </main>
  </body>
</html>
