---
import Layout from '../layouts/Layout.astro';
import { siteUrl } from '../utils/site';
---

<Layout title="Page Not Found" description="The page you're looking for doesn't exist.">
  <section class="flex min-h-[60vh] flex-col items-center justify-center bg-white px-6 py-20 text-center">
    <h1 class="mb-4 font-bebas text-[80px] font-semibold leading-none tracking-[1.4px] text-primary md:text-[120px]">
      404
    </h1>
    <p class="mb-8 text-lg text-body">
      Oops! The page you're looking for doesn't exist.
    </p>
    <a
      href="/"
      class="inline-block min-h-[44px] rounded bg-primary px-8 py-3 font-bebas text-xl tracking-wider text-white transition-transform hover:scale-105 motion-reduce:hover:scale-100"
    >
      Back to Home
    </a>
  </section>

  <footer class="bg-primary py-4 px-6 text-center text-sm text-white">
    <p class="m-0">&copy; {new Date().getFullYear()} Sparkle. All rights reserved. Powered by <a href="https://spiritmedia.us" target="_blank" rel="noopener noreferrer" class="underline hover:text-white/80">Spirit Media</a>.</p>
  </footer>
</Layout>
