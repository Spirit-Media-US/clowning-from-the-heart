---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Page Not Found"
  description="The page you're looking for doesn't exist."
>
  <section class="not-found">
    <div class="container not-found-inner">
      <div class="not-found-icon" aria-hidden="true">🎪</div>
      <h1>Oops — That Page Doesn't Exist</h1>
      <p>It looks like you've wandered off the path. Let's get you back to somewhere fun.</p>
      <a href="/" class="btn btn--primary">Back to Homepage</a>
    </div>
  </section>
</Layout>

<style>
  .not-found {
    min-height: 60vh;
    display: flex;
    align-items: center;
    background: linear-gradient(135deg, #fff0f0 0%, #fff8e1 100%);
  }

  .not-found-inner {
    text-align: center;
    padding-block: 4rem;
  }

  .not-found-icon {
    font-size: 5rem;
    margin-bottom: 1.5rem;
  }

  h1 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    color: #1a1a1a;
    margin: 0 0 1rem;
  }

  p {
    font-size: 1.125rem;
    color: #4b5563;
    margin: 0 0 2rem;
    max-width: 45ch;
    margin-inline: auto;
    margin-bottom: 2rem;
  }

  .btn {
    display: inline-block;
    padding: 0.75rem 1.75rem;
    border-radius: 9999px;
    font-size: 1rem;
    font-weight: 600;
    background: #e63946;
    color: #fff;
    transition: background 0.15s;
  }

  .btn:hover {
    background: #c1121f;
  }
</style>
