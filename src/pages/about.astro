---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import SectionHeading from '../components/SectionHeading.astro';
---

<Layout
  title="About Us"
  description="Learn about our story, our mission, and the heart behind Clowning from the Heart."
  canonicalPath="/about"
>

  <!-- Hero -->
  <Hero
    title="The Heart Behind the Smile"
    intro="We started with a simple belief: that laughter is one of the greatest gifts we can give each other."
    ctaPrimary={{ label: 'Book an Event', href: '/contact' }}
    variant="page"
  />

  <!-- Mission / Story -->
  <section class="section">
    <div class="container story-layout">
      <div>
        <SectionHeading
          eyebrow="Our Story"
          heading="How It All Began"
          body="Clowning from the Heart was born out of a passion for bringing genuine joy to people of all ages. What started as a calling to serve others through laughter has grown into a full-service entertainment company dedicated to creating meaningful moments."
        />
        <p class="story-text">
          [Placeholder — your founding story goes here. Share how you started, what inspired you, and what makes your approach different from other entertainment services.]
        </p>
        <p class="story-text">
          [Continue your story. Talk about key moments, growth, or memorable experiences that shaped the business into what it is today.]
        </p>
      </div>
      <div class="story-image-placeholder" aria-hidden="true">
        <span>📸 Photo Placeholder</span>
        <p>Image will be served from Cloudflare R2</p>
      </div>
    </div>
  </section>

  <!-- Mission -->
  <section class="section section--alt">
    <div class="container">
      <SectionHeading
        eyebrow="Our Mission"
        heading="Spreading Joy with Purpose"
        body="We believe every person deserves to experience genuine laughter. Our mission is to create moments of connection, warmth, and delight — one event at a time."
        align="center"
      />
      <blockquote class="mission-quote">
        "Joy is not just what we do — it's who we are."
      </blockquote>
    </div>
  </section>

  <!-- Values / Approach -->
  <section class="section">
    <div class="container">
      <SectionHeading
        eyebrow="Our Approach"
        heading="Values We Perform By"
      />
      <div class="values-grid">
        {[
          { icon: '❤️', title: 'Authenticity', body: 'We show up as ourselves — genuine, warm, and fully present for every audience.' },
          { icon: '🎭', title: 'Craft', body: 'Every performance is rehearsed, refined, and delivered with professional artistry.' },
          { icon: '🌈', title: 'Inclusion', body: 'Our entertainment is designed to welcome and delight people of all backgrounds and abilities.' },
          { icon: '🤝', title: 'Service', body: 'We are here to serve you and your guests. Your event\'s success is our top priority.' },
          { icon: '✨', title: 'Wonder', body: 'We aim to spark that childlike sense of amazement that reminds us all of the magic in everyday life.' },
          { icon: '🛡️', title: 'Safety', body: 'We maintain safe, appropriate, family-friendly entertainment standards at every event.' },
        ].map((value) => (
          <div class="value-card">
            <div class="value-icon" aria-hidden="true">{value.icon}</div>
            <h3>{value.title}</h3>
            <p>{value.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section cta-section">
    <div class="container" style="text-align: center;">
      <SectionHeading
        eyebrow="Work With Us"
        heading="Let's Make Something Wonderful Together"
        body="We'd love to be part of your next event. Reach out and let's start the conversation."
        align="center"
      />
      <a href="/contact" class="btn btn--primary">Get in Touch</a>
    </div>
  </section>

</Layout>

<style>
  .section--alt {
    background: #fafafa;
  }

  .story-layout {
    display: grid;
    gap: 3rem;
  }

  @media (min-width: 768px) {
    .story-layout {
      grid-template-columns: 1fr 1fr;
      align-items: start;
    }
  }

  .story-text {
    color: #4b5563;
    line-height: 1.75;
    margin: 0 0 1rem;
  }

  .story-image-placeholder {
    background: #f3f4f6;
    border: 2px dashed #d1d5db;
    border-radius: 0.75rem;
    aspect-ratio: 4/3;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    color: #9ca3af;
    font-size: 0.9rem;
    text-align: center;
  }

  .story-image-placeholder span {
    font-size: 1.25rem;
  }

  .story-image-placeholder p {
    margin: 0;
    font-size: 0.8125rem;
  }

  .mission-quote {
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    font-style: italic;
    color: #e63946;
    text-align: center;
    border: none;
    margin: 2rem auto 0;
    max-width: 600px;
    padding: 0;
    font-weight: 600;
  }

  .values-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.5rem;
  }

  .value-card {
    padding: 1.75rem;
    border: 1px solid #e5e7eb;
    border-radius: 0.75rem;
    background: #fff;
  }

  .value-icon {
    font-size: 2rem;
    margin-bottom: 0.75rem;
  }

  .value-card h3 {
    font-size: 1.0625rem;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0 0 0.5rem;
  }

  .value-card p {
    font-size: 0.9rem;
    color: #4b5563;
    margin: 0;
    line-height: 1.6;
  }

  .cta-section {
    background: linear-gradient(135deg, #fff0f0 0%, #fff8e1 100%);
  }

  .btn {
    display: inline-block;
    padding: 0.75rem 1.75rem;
    border-radius: 9999px;
    font-size: 1rem;
    font-weight: 600;
    transition: background 0.15s;
  }

  .btn--primary {
    background: #e63946;
    color: #fff;
  }

  .btn--primary:hover {
    background: #c1121f;
  }
</style>
