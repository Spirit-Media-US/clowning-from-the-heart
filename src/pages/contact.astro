---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { contactInfo } from '../utils/site';
---

<Layout
  title="Contact Us"
  description="Get in touch to book an event, ask a question, or learn more about our entertainment services."
  canonicalPath="/contact"
>

  <!-- Hero -->
  <Hero
    title="Let's Connect"
    intro="We'd love to hear from you. Reach out with questions, event details, or just to say hello."
    variant="page"
  />

  <!-- Contact Section -->
  <section class="section">
    <div class="container contact-layout">

      <!-- Contact Info -->
      <div class="contact-info">
        <SectionHeading
          eyebrow="Get in Touch"
          heading="We're Here to Help"
          body="Whether you're ready to book or just have a question, we'd love to talk. Here's how to reach us."
        />

        <div class="contact-methods">
          <div class="contact-method">
            <div class="method-icon" aria-hidden="true">📧</div>
            <div>
              <p class="method-label">Email</p>
              <a href={`mailto:${contactInfo.email}`} class="method-value">{contactInfo.email}</a>
            </div>
          </div>
          <div class="contact-method">
            <div class="method-icon" aria-hidden="true">📞</div>
            <div>
              <p class="method-label">Phone</p>
              <a href={`tel:${contactInfo.phone.replace(/\D/g, '')}`} class="method-value">{contactInfo.phone}</a>
            </div>
          </div>
          <div class="contact-method">
            <div class="method-icon" aria-hidden="true">📍</div>
            <div>
              <p class="method-label">Location</p>
              <p class="method-value">{contactInfo.location}</p>
            </div>
          </div>
          <div class="contact-method">
            <div class="method-icon" aria-hidden="true">🕐</div>
            <div>
              <p class="method-label">Response Time</p>
              <p class="method-value">Within 1–2 business days</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Form Embed Placeholder -->
      <div class="form-area">
        <SectionHeading
          eyebrow="Book an Event"
          heading="Send Us a Message"
        />

        <!-- GoHighLevel form embed will go here -->
        <div class="form-placeholder">
          <div class="form-placeholder-inner">
            <p class="placeholder-label">📋 Booking Form</p>
            <p class="placeholder-note">
              A GoHighLevel booking form will be embedded here.
            </p>
            <code class="placeholder-code">
              &lt;!-- GoHighLevel Form Embed --&gt;<br />
              &lt;!-- Replace this block with your GHL embed code --&gt;
            </code>
            <p class="placeholder-hint">
              Set <code>GHL_FORM_EMBED_URL</code> in your <code>.env</code> file when ready.
            </p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- FAQ Placeholder -->
  <section class="section section--alt">
    <div class="container">
      <SectionHeading
        eyebrow="Common Questions"
        heading="Frequently Asked Questions"
        body="A few things people often ask before booking."
      />
      <div class="faq-list">
        {[
          {
            q: 'How far in advance should I book?',
            a: 'We recommend booking at least 2–4 weeks in advance, especially for weekends and holidays. Popular dates fill up fast!',
          },
          {
            q: 'What areas do you serve?',
            a: '[Placeholder — describe your service area here.]',
          },
          {
            q: 'What does a typical booking include?',
            a: '[Placeholder — describe what clients receive when they book with you.]',
          },
          {
            q: 'Do you perform for adults or just children?',
            a: 'We love all ages! Our entertainment is crafted to delight audiences from toddlers to grandparents.',
          },
        ].map((item) => (
          <div class="faq-item">
            <h3>{item.q}</h3>
            <p>{item.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

</Layout>

<style>
  .section--alt {
    background: #fafafa;
  }

  .contact-layout {
    display: grid;
    gap: 3rem;
  }

  @media (min-width: 768px) {
    .contact-layout {
      grid-template-columns: 1fr 1fr;
      align-items: start;
    }
  }

  .contact-methods {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-top: 0.5rem;
  }

  .contact-method {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }

  .method-icon {
    font-size: 1.5rem;
    flex-shrink: 0;
    margin-top: 0.125rem;
  }

  .method-label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #6b7280;
    margin: 0 0 0.25rem;
  }

  .method-value {
    font-size: 1rem;
    color: #1a1a1a;
    margin: 0;
    display: block;
  }

  a.method-value {
    color: #e63946;
  }

  a.method-value:hover {
    text-decoration: underline;
  }

  .form-placeholder {
    border: 2px dashed #d1d5db;
    border-radius: 0.75rem;
    background: #fafafa;
    padding: 2rem;
  }

  .form-placeholder-inner {
    text-align: center;
    color: #6b7280;
  }

  .placeholder-label {
    font-size: 1.25rem;
    font-weight: 700;
    color: #374151;
    margin: 0 0 0.5rem;
  }

  .placeholder-note {
    font-size: 0.9375rem;
    margin: 0 0 1.25rem;
  }

  .placeholder-code {
    display: block;
    background: #f3f4f6;
    border: 1px solid #e5e7eb;
    border-radius: 0.5rem;
    padding: 1rem;
    font-size: 0.8125rem;
    text-align: left;
    color: #374151;
    margin-bottom: 1rem;
    line-height: 1.8;
  }

  .placeholder-hint {
    font-size: 0.8125rem;
    color: #9ca3af;
    margin: 0;
  }

  .placeholder-hint code {
    background: #f3f4f6;
    padding: 0.1em 0.35em;
    border-radius: 0.25rem;
    font-size: 0.8em;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid #e5e7eb;
    border-radius: 0.75rem;
    overflow: hidden;
    background: #fff;
  }

  .faq-item {
    padding: 1.5rem 1.75rem;
    border-bottom: 1px solid #e5e7eb;
  }

  .faq-item:last-child {
    border-bottom: none;
  }

  .faq-item h3 {
    font-size: 1rem;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0 0 0.5rem;
  }

  .faq-item p {
    font-size: 0.9375rem;
    color: #4b5563;
    margin: 0;
    line-height: 1.6;
  }
</style>
