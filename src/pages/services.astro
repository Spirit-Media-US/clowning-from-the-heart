---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import SectionHeading from '../components/SectionHeading.astro';

const services = [
  {
    icon: '🎂',
    name: 'Birthday Parties',
    desc: 'Make their special day truly unforgettable. We bring balloon art, magic, interactive games, and big laughs to birthday celebrations for kids and adults alike.',
    highlights: ['Balloon twisting', 'Magic tricks', 'Interactive games', 'Party favors'],
  },
  {
    icon: '🏥',
    name: 'Hospital & Care Visits',
    desc: 'Bringing smiles to patients, families, and staff in hospitals, care homes, and rehabilitation centers. These visits are among our most meaningful performances.',
    highlights: ['Bedside visits', 'Common area shows', 'Family-friendly', 'Sensitive & compassionate'],
  },
  {
    icon: '🎡',
    name: 'Community Events',
    desc: 'From local festivals to school fairs, we bring high-energy entertainment that engages crowds of all sizes and ages.',
    highlights: ['Festivals & fairs', 'School events', 'Parades', 'Community fundraisers'],
  },
  {
    icon: '🏢',
    name: 'Corporate Events',
    desc: 'Add a memorable and lighthearted touch to company celebrations, team-building events, client appreciation days, and holiday parties.',
    highlights: ['Company parties', 'Team building', 'Client events', 'Holiday celebrations'],
  },
  {
    icon: '⛪',
    name: 'Church & Community Groups',
    desc: 'We love serving faith communities and nonprofit organizations with uplifting, family-friendly entertainment for all generations.',
    highlights: ['Church events', 'VBS', 'Nonprofit fundraisers', 'Community outreach'],
  },
  {
    icon: '🎓',
    name: 'School & Educational Events',
    desc: 'Interactive and age-appropriate entertainment for assemblies, field days, end-of-year celebrations, and literacy events.',
    highlights: ['School assemblies', 'Field days', 'Reading programs', 'Graduation parties'],
  },
];
---

<Layout
  title="Services"
  description="From birthday parties to hospital visits, we offer a full range of professional clown entertainment services for every occasion."
  canonicalPath="/services"
>

  <!-- Hero -->
  <Hero
    title="Entertainment for Every Occasion"
    intro="Whether it's an intimate birthday party or a large community event, we bring laughter, wonder, and warmth that your guests will never forget."
    ctaPrimary={{ label: 'Book an Event', href: '/contact' }}
    ctaSecondary={{ label: 'Learn About Us', href: '/about' }}
    variant="page"
  />

  <!-- Services List -->
  <section class="section">
    <div class="container">
      <SectionHeading
        eyebrow="What We Do"
        heading="Our Services"
        body="We tailor every performance to the event, audience, and occasion. Here's how we can serve you."
      />
      <div class="services-grid">
        {services.map((service) => (
          <article class="service-card">
            <div class="service-icon" aria-hidden="true">{service.icon}</div>
            <h3>{service.name}</h3>
            <p>{service.desc}</p>
            <ul class="service-highlights">
              {service.highlights.map((h) => (
                <li>{h}</li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Process / How It Works -->
  <section class="section section--alt">
    <div class="container">
      <SectionHeading
        eyebrow="How It Works"
        heading="From Inquiry to Event Day"
        body="Booking entertainment should be easy and stress-free. Here's our simple process."
        align="center"
      />
      <div class="process-steps">
        {[
          { step: '01', title: 'Reach Out', body: 'Contact us with your event details — date, type, audience size, and any special requests.' },
          { step: '02', title: 'We Customize', body: 'We\'ll put together a tailored plan that fits your event, audience, and budget.' },
          { step: '03', title: 'Confirm & Book', body: 'Review the proposal, sign a simple agreement, and lock in your date.' },
          { step: '04', title: 'We Show Up & Delight', body: 'We arrive ready to perform and leave your guests with smiles they\'ll carry long after the event.' },
        ].map((s) => (
          <div class="process-step">
            <div class="step-number" aria-hidden="true">{s.step}</div>
            <div class="step-content">
              <h3>{s.title}</h3>
              <p>{s.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section cta-section">
    <div class="container" style="text-align: center;">
      <SectionHeading
        eyebrow="Let's Plan Your Event"
        heading="Ready to Bring the Joy?"
        body="Contact us today and let's talk about how we can make your next event truly memorable."
        align="center"
      />
      <a href="/contact" class="btn btn--primary">Book Now</a>
    </div>
  </section>

</Layout>

<style>
  .section--alt {
    background: #fafafa;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .service-card {
    padding: 2rem;
    border: 1px solid #e5e7eb;
    border-radius: 0.75rem;
    background: #fff;
  }

  .service-icon {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .service-card h3 {
    font-size: 1.1875rem;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0 0 0.75rem;
  }

  .service-card p {
    font-size: 0.9375rem;
    color: #4b5563;
    margin: 0 0 1.25rem;
    line-height: 1.6;
  }

  .service-highlights {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .service-highlights li {
    font-size: 0.8125rem;
    font-weight: 600;
    background: #fff0f0;
    color: #e63946;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    border: 1px solid #fecaca;
  }

  .process-steps {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    max-width: 700px;
    margin-inline: auto;
  }

  .process-step {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
  }

  .step-number {
    flex-shrink: 0;
    width: 3rem;
    height: 3rem;
    background: #e63946;
    color: #fff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8125rem;
    font-weight: 800;
  }

  .step-content h3 {
    font-size: 1.0625rem;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0 0 0.4rem;
  }

  .step-content p {
    font-size: 0.9375rem;
    color: #4b5563;
    margin: 0;
    line-height: 1.6;
  }

  .cta-section {
    background: linear-gradient(135deg, #fff0f0 0%, #fff8e1 100%);
  }

  .btn {
    display: inline-block;
    padding: 0.75rem 1.75rem;
    border-radius: 9999px;
    font-size: 1rem;
    font-weight: 600;
    transition: background 0.15s;
  }

  .btn--primary {
    background: #e63946;
    color: #fff;
  }

  .btn--primary:hover {
    background: #c1121f;
  }
</style>
